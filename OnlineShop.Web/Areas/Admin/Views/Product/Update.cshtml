@model UpdateProductViewModel
@{
    ViewData["Title"] = "Редактирование товара";
}

<div class="text-center text-uppercase text-success mb-5 mt-5">
    <h2 class="row-title">Редактирование товара</h2>
</div>
<form method="post" enctype="multipart/form-data">
    <div class="row justify-content-center mt-3">
        <div class="col-6 mb-3">
            <input type="hidden" name="Id" value="@Model.Id" />
            <div asp-validation-summary="All" class="text-uppercase text-danger fw-bold"></div>

            <!-- Основная информация о товаре -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Основная информация</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold">Наименование товара</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Cost" class="form-label fw-bold">Цена, руб.</label>
                        <input asp-for="Cost" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="Cost" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold">Описание товара</label>
                        <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <!-- Существующие изображения -->
            @if (Model.ExistingImages.Any())
            {
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Существующие изображения</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">Отметьте изображения, которые нужно удалить:</p>
                        <div class="row">
                            @for (int i = 0; i < Model.ExistingImages.Count; i++)
                            {
                                <div class="col-md-4 col-sm-6 mb-4">
                                    <div class="card h-100">
                                        <div class="text-center p-3" style="height: 200px;">
                                            <img src="@Model.ExistingImages[i].ImagePath"
                                                 style="max-width: 100%; max-height: 100%; object-fit: contain;"
                                                 class="img-fluid"
                                                 alt="Изображение товара" />
                                        </div>
                                        <div class="card-body p-3">
                                            <div class="form-check">
                                                <input type="checkbox"
                                                       class="form-check-input"
                                                       id="delete_@Model.ExistingImages[i].Id"
                                                       name="ImagesToDelete"
                                                       value="@Model.ExistingImages[i].Id" />
                                                <label class="form-check-label text-danger" for="delete_@Model.ExistingImages[i].Id">
                                                    Отметить на удаление
                                                </label>
                                            </div>
                                            @if (Model.ExistingImages[i].IsMain)
                                            {
                                                <div class="mt-2">
                                                    <span class="badge bg-success">Основное изображение</span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Добавление новых изображений -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Добавить новые изображения</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Выберите изображения для загрузки</label>
                        <input name="NewImages" value="NewImages" type="file" class="form-control" multiple accept="image/jpeg,image/png,image/gif,image/webp" />
                        <div class="form-text mt-2">
                            <strong>Поддерживаемые форматы:</strong> JPG, PNG, GIF, WEBP.<br />
                            <strong>Максимальный размер:</strong> 5MB на файл.<br />
                            <strong>Можно выбрать несколько файлов:</strong> удерживайте Ctrl (или Cmd на Mac) при выборе файлов.
                        </div>
                    </div>
                </div>
            </div>


        </div>
    </div>
    <div class="text-center m-3">
        <button class="btn btn-outline-success" type="submit"
                asp-area="Admin"
                asp-controller="Product"
                asp-action="Update">
            Обновить
        </button>
    </div>
</form>