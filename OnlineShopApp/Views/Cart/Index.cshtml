@model CartViewModel

<div class="row justify-content-evenly">

    @if (Model != null && Model.Items?.Count > 0)
    {
        <div class="col-9">
            <table class="table table-responsive table-striped table-hover mb-5">
                <thead>
                    <tr align="center">
                        <th scope="col">#</th>
                        <th scope="col">Наименование товара</th>
                        <th scope="col">Цена, руб.</th>
                        <th scope="col">Количество, шт.</th>
                        <th scope="col">Стоимость, руб.</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cartItem in Model.CartItemsWithIndex)
                    {
                        <tr align="center">
                            <td class="fw-bold">@cartItem.Index</td>
                            <td align="left">@cartItem.Item.ProductName</td>
                            <td align="left">@cartItem.Item.FormattedProductPrice</td>
                            <td>
                                <a class="btn btn-success me-2"
                                   asp-controller="Cart"
                                   asp-action="Decrease"
                                   asp-route-productId="@cartItem.Item.ProductId">-</a>
                                @cartItem.Item.Quantity
                                <a class="btn btn-success ms-2"
                                   asp-controller="Cart"
                                   asp-action="Increase"
                                   asp-route-productId="@cartItem.Item.ProductId">+</a>
                            </td>
                            <td class="fw-bold">@cartItem.Item.FormattedTotalCost</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr align="center">
                        <th colspan="2"></th>
                        <th colspan="2">
                            Общая стоимость: @Model.FormattedTotalCost
                        </th>
                        <th colspan="1">
                            <a class="btn btn-success"
                               asp-controller="Order"
                               asp-action="Index">
                                Оформить заказ
                            </a>
                        </th>
                    </tr>
                </tfoot>
            </table>

        </div>

        <div class="row justify-content-center">
            <div class="col-auto m-4">
                <a class="btn btn-outline-danger"
                   asp-controller="Cart"
                   asp-action="Clear">
                    Очистить корзину
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="col-auto m-5">
            <h2 class="row-title">В корзине нет товаров!</h2>
        </div>

    }
</div>

<div class="row justify-content-center">
    <div class="col-auto m-4">
        <a class="btn btn-outline-success"
           asp-controller="Home"
           asp-action="Index">
            Продолжить покупки
        </a>
    </div>
</div>