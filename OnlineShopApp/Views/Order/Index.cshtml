@model OrderViewModel
@{
    ViewData["Title"] = "Оформление заказа";
}

<div class="text-center text-uppercase text-success mb-5 mt-5">
    <h2 class="row-title">Оформление заказа</h2>
</div>

@if (Model != null && Model.Items?.Count > 0)
{
    <form method="post">
        <div class="row justify-content-center mt-3">
            <div class="col">
                <table class="table table-borderless">
                    <thead>
                        <tr align="center">
                            <th><h2>Информация о покупателе</h2></th>
                            <th><h2>Информация о заказе</h2></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="w-50 p-4">
                                <div asp-validation-summary="All" class="text-uppercase text-danger fw-bold"></div>
                                <p>
                                    <label asp-for="DeliveryUser.Name" class="form-label"></label><br />
                                    <input asp-for="DeliveryUser.Name" class="form-control" />
                                    <span asp-validation-for="DeliveryUser.Name" class="text-danger"></span>
                                </p>
                                <p>
                                    <label asp-for="DeliveryUser.Address" class="form-label"></label><br />
                                    <input asp-for="DeliveryUser.Address" class="form-control" />
                                    <span asp-validation-for="DeliveryUser.Address" class="text-danger"></span>
                                </p>
                                <p>
                                    <label asp-for="DeliveryUser.Phone" class="form-label"></label><br />
                                    <input asp-for="DeliveryUser.Phone" class="form-control" />
                                    <span asp-validation-for="DeliveryUser.Phone" class="text-danger"></span>
                                </p>
                                <p>
                                    <label asp-for="DeliveryUser.Date" class="form-label"></label>
                                    <input asp-for="DeliveryUser.Date" class="form-control" />
                                    <span asp-validation-for="DeliveryUser.Date" class="text-danger"></span>
                                </p>
                                <p>
                                    <label asp-for="DeliveryUser.Comment" class="form-label"></label>
                                    <textarea asp-for="DeliveryUser.Comment" class="form-control"></textarea>
                                    <span asp-validation-for="DeliveryUser.Comment" class="text-danger"></span>
                                </p>
                            </td>

                            <td class="w-50 p-4">
                                <table class="table table-responsive table-striped table-hover mb-5 caption-top">
                                    <thead>
                                        <tr align="center">
                                            <th scope="col">#</th>
                                            <th scope="col">Наименование товара</th>
                                            <th scope="col">Цена, руб.</th>
                                            <th scope="col">Количество, шт.</th>
                                            <th scope="col">Стоимость, руб.</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for(int i = 0; i < Model.Items.Count ; i++)
                                        @*@foreach (var orderItem in Model.OrderItemsWithIndex)*@
                                        {
                                            <tr align="center" class="align-baseline">
                                                <td class="fw-bold">
                                                    @(i+1)
                                                </td>
                                                <td align="left">
                                                    @Model.Items[i].ProductName
                                                </td>
                                                <td align="left">
                                                    @Model.Items[i].ProductPrice
                                                </td>
                                                <td>
                                                    @Model.Items[i].Quantity
                                                </td>
                                                <td class="fw-bold">
                                                    @Model.Items[i].TotalCost
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot class="table-borderless ">
                                        <tr align="center">
                                            <th colspan="5">
                                                Общая стоимость заказа: @Model.FormattedTotalCost;
                                            </th>
                                        </tr>
                                    </tfoot>
                                </table>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="text-center">
            <button class="btn btn-outline-danger" type="submit"
                    asp-controller="Order"
                    asp-action="AddOrder">
                Оплатить заказ
            </button>
        </div>
    </form>
}
else
{
    <div class="text-center">
        <h2 class="row-title">Нет заказа для оформления!</h2>
    </div>
}

<div class="text-center m-5">
    <a class="btn btn-outline-success"
       asp-controller="Home"
       asp-action="Index">
        Продолжить покупки
    </a>
</div>
